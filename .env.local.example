# Copy to .env.local and fill in from your Supabase project
# (Supabase Dashboard -> Project Settings -> API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# New Supabase key model: use the PUBLISHABLE key (sb_publishable_...).
# It is safe to expose in the browser; access is enforced by RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Legacy alternative (still works): the anon key. The app accepts either —
# it prefers PUBLISHABLE_KEY and falls back to ANON_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key

# NOTE: never put the secret key (sb_secret_...) / service_role here.
# This app does not use it — everything goes through RLS + the user session.

# Optional: lock the owner (DM) view to one account. If set, only this email
# sees the dashboard/editor entry; everyone else (and signed-out visitors) get
# the player view at "/". If unset, any signed-in user is treated as the owner.
# NEXT_PUBLIC_OWNER_EMAIL=you@example.com
